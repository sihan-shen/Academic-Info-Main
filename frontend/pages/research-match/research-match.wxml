<view class="page">
  <!-- 表单区域 -->
  <view class="form-section">
    <view class="form-title">填写您的研究需求</view>
    <view class="form-sub">智能匹配最适合您的导师</view>

    <view class="field">
      <view class="field-label">学科方向 <text class="required">*</text></view>
      <input class="field-input" placeholder="请输入学科方向" bindinput="onFieldInput" data-key="discipline" value="{{discipline}}" />
    </view>

    <view class="field">
      <view class="field-label">研究兴趣关键词 <text class="required">*</text></view>
      <input class="field-input" placeholder="请输入您的研究兴趣关键词，多个关键词用逗号分隔" bindinput="onFieldInput" data-key="keywords" value="{{keywords}}" />
    </view>

    <view class="pref-section">
      <view class="pref-title">匹配偏好</view>
      <view class="pref-item" bindtap="togglePref" data-key="crossSchool">
        <view class="checkbox {{prefs.crossSchool ? 'checked' : ''}}">
          <text wx:if="{{prefs.crossSchool}}">✓</text>
        </view>
        <text>优先跨校合作</text>
      </view>
      <view class="pref-item" bindtap="togglePref" data-key="highOutput">
        <view class="checkbox {{prefs.highOutput ? 'checked' : ''}}">
          <text wx:if="{{prefs.highOutput}}">✓</text>
        </view>
        <text>优先高成果导师</text>
      </view>
      <view class="pref-item" bindtap="togglePref" data-key="youngScholar">
        <view class="checkbox {{prefs.youngScholar ? 'checked' : ''}}">
          <text wx:if="{{prefs.youngScholar}}">✓</text>
        </view>
        <text>优先青年学者</text>
      </view>
    </view>

    <view class="match-btn" bindtap="onMatch">一键匹配</view>
  </view>

  <!-- 结果区域 -->
  <view class="result-section" wx:if="{{matched}}">
    <view class="result-title">为您找到 <text class="result-num">{{tutors.length}}</text> 位匹配导师</view>

    <view class="tutor-card" wx:for="{{tutors}}" wx:key="id">
      <!-- 顶部：匹配度 -->
      <view class="card-top">
        <view class="match-tag {{item.level === '高度适配' ? 'tag-high' : 'tag-normal'}}">{{item.level}}</view>
        <view class="match-score-wrapper">
          <text class="match-score">{{item.matchScore}}%</text>
          <text class="match-label">研究方向匹配度</text>
        </view>
      </view>

      <!-- 导师信息 -->
      <view class="tutor-info" bindtap="viewTutorDetail" data-id="{{item.id}}">
        <image class="tutor-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="tutor-detail">
          <view class="tutor-name">{{item.name}}</view>
          <view class="tutor-title">{{item.title}}</view>
          <view class="tutor-univ">{{item.university}} · {{item.department}}</view>
        </view>
      </view>

      <!-- 标签 -->
      <view class="tag-row">
        <view class="tag blue" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</view>
      </view>

      <!-- 高影响力论文 -->
      <view class="paper-row">
        <text class="paper-label">高影响力论文 {{item.papers}}篇</text>
        <text class="paper-link" bindtap="viewTutorDetail" data-id="{{item.id}}">查看 ></text>
      </view>

      <!-- 匹配原因 -->
      <view class="reason-row">
        <text class="reason-label">匹配原因：</text>
        <text class="reason-text">{{item.reason}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="action-row">
        <view class="btn-collect" bindtap="onCollect" data-id="{{item.id}}">☆ 收藏导师</view>
        <view class="btn-contact" bindtap="viewTutorDetail" data-id="{{item.id}}">查看详情 ></view>
      </view>
    </view>
  </view>

  <!-- 无结果 -->
  <view class="empty-state" wx:if="{{matched && tutors.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">未找到匹配的导师</text>
    <text class="empty-subtitle">请尝试调整关键词或学科方向</text>
  </view>
</view>
