.page {
  min-height: 100vh;
  background: #f0f4fa;
  padding-bottom: 60rpx;
}

/* ========== 表单区域 ========== */
.form-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.form-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.form-sub {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 36rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #e74c3c;
}

.field-input {
  border: 2rpx solid #d8dfe8;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
}

/* ========== 匹配偏好 ========== */
.pref-section {
  margin-top: 12rpx;
  margin-bottom: 36rpx;
}

.pref-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.pref-item {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #c0c8d4;
  border-radius: 6rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background: #fff;
}

.checkbox.checked {
  background: #3468b5;
  border-color: #3468b5;
}

.pref-item text {
  font-size: 28rpx;
  color: #444;
}

/* ========== 匹配按钮 ========== */
.match-btn {
  background: #3468b5;
  color: #fff;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.match-btn:active {
  opacity: 0.85;
}

/* ========== 结果区域 ========== */
.result-section {
  padding: 0 24rpx;
  margin-top: 8rpx;
}

.result-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 24rpx;
  font-weight: bold;
}

.result-num {
  color: #3468b5;
}

/* ========== 导师卡片 ========== */
.tutor-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.match-tag {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.tag-high {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-normal {
  background: #e8f0fe;
  color: #3468b5;
}

.match-rate {
  font-size: 22rpx;
  color: #999;
}

/* 导师信息 */
.tutor-info {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.tutor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #e0e0e0;
}

.tutor-detail {
  flex: 1;
}

.tutor-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.tutor-univ {
  font-size: 24rpx;
  color: #888;
}

/* 标签 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tag.blue {
  background: #e8f0fe;
  color: #3468b5;
}

/* 论文行 */
.paper-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.paper-label {
  font-size: 24rpx;
  color: #666;
}

.paper-link {
  font-size: 24rpx;
  color: #3468b5;
}

/* 匹配原因 */
.reason-row {
  margin-bottom: 22rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.reason-label {
  color: #3468b5;
  font-weight: bold;
}

.reason-text {
  color: #555;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
}

.btn-collect {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  border: 2rpx solid #d0d8e4;
  font-size: 26rpx;
  color: #555;
  background: #fff;
}

.btn-contact {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #fff;
  background: #3468b5;
}

.btn-collect:active {
  background: #f5f5f5;
}

.btn-contact:active {
  opacity: 0.85;
}
