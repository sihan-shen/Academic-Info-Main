/* pages/research-match/research-match.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f0fe 0%, #f5f7fa 100%);
  padding-bottom: 60rpx;
}

/* ========== 表单区域 ========== */
.form-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.form-sub {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 36rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required {
  color: #e74c3c;
}

.field-input {
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.pref-section {
  margin-top: 32rpx;
}

.pref-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.pref-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #555;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d8dfe8;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #3468b5;
  border-color: #3468b5;
}

.match-btn {
  background: linear-gradient(135deg, #3468b5 0%, #2c5aa0 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(52, 104, 181, 0.3);
}

.match-btn.loading {
  opacity: 0.8;
}

.match-btn:active {
  transform: scale(0.98);
}

/* ========== 结果区域 ========== */
.result-section {
  padding: 0 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 36rpx 0 24rpx;
  padding-left: 8rpx;
}

.result-num {
  color: #3468b5;
  font-weight: bold;
}

/* ========== 导师卡片 ========== */
.tutor-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.match-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.match-tag.tag-high {
  background: #e8f5e9;
  color: #2e7d32;
}

.match-tag.tag-normal {
  background: #e8f0fe;
  color: #3468b5;
}

.match-score-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.match-score {
  font-size: 44rpx;
  font-weight: bold;
  color: #3468b5;
  line-height: 1.2;
}

.match-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

/* 导师信息 */
.tutor-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tutor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tutor-detail {
  flex: 1;
}

.tutor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.tutor-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.tutor-univ {
  font-size: 24rpx;
  color: #888;
}

/* 标签 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tag.blue {
  background: #e8f0fe;
  color: #3468b5;
}

/* 论文 */
.paper-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.paper-label {
  font-size: 26rpx;
  color: #555;
}

.paper-link {
  font-size: 24rpx;
  color: #3468b5;
}

/* 匹配原因 */
.reason-row {
  background: #f8f9fa;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 28rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #3468b5;
  font-weight: 500;
}

.reason-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 24rpx;
}

.btn-collect {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #555;
  border: 2rpx solid #e0e0e0;
  background: #fff;
}

.btn-contact {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #3468b5 0%, #2c5aa0 100%);
  box-shadow: 0 4rpx 12rpx rgba(52, 104, 181, 0.3);
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #999;
  display: block;
}
