/** pages/login/login.wxss */
.container {
  background-color: #f9fafb;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
}

.header {
  position: relative;
  width: 100%;
  height: 424rpx;
}

.header-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
  padding-top: 64rpx;
  text-align: center;
  color: white;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 40rpx;
  opacity: 0.9;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.divider {
  opacity: 0.6;
}

.login-form {
  background: white;
  margin-top: -40rpx;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 60rpx 40rpx;
  flex: 1;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #364153;
  margin-bottom: 16rpx;
}

.required {
  color: #fb2c36;
}

.input-box {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
}

.input-box input {
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: rgba(54, 65, 83, 0.5);
}

.login-btn {
  background: #2b7fff;
  color: white;
  border-radius: 32rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  margin-top: 60rpx;
  box-shadow: 0 20rpx 30rpx rgba(0,0,0,0.1);
}

.login-btn::after {
  border: none;
}

.wechat-login-btn {
  background: #07c160;
  color: white;
  border-radius: 32rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.2);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  background: #06ad56;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
}

.links {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #155dfc;
}

.agreement {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  font-size: 24rpx;
  color: #364153;
  line-height: 1.5;
  margin-left: 10rpx;
}

.link {
  color: #2b7fff;
}
