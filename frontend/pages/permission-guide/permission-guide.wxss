/** pages/permission-guide/permission-guide.wxss **/

page {
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  min-height: 100vh;
}

.page {
  padding: 0 32rpx 120rpx;
  box-sizing: border-box;
}

/* 插图区域 */
.illustration-box {
  padding: 80rpx 0 60rpx;
  text-align: center;
}

.illustration-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.illustration-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 权限说明 */
.info-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 操作步骤 */
.steps-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.steps-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #3468b5 0%, #5a8fd9 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(52, 104, 181, 0.3);
}

.step-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding-top: 6rpx;
}

/* 权限范围 */
.scope-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.scope-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.scope-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.scope-item:last-child {
  margin-bottom: 0;
}

.scope-icon {
  width: 32rpx;
  height: 32rpx;
  background: #e6f7ed;
  color: #27ae60;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.scope-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部按钮 */
.button-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #f5f6f8;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-cancel:active {
  background: #e8e9eb;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #3468b5 0%, #5a8fd9 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(52, 104, 181, 0.3);
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  opacity: 0.8;
}

/* 隐私提示 */
.privacy-tip {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  max-width: 500rpx;
}
