.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #fff;
  padding: 0;
  box-sizing: border-box;
}

.main-scroll {
  flex: 1;
  overflow-y: auto;
  /* Ensure scroll view takes remaining space */
}

.content-wrapper {
  padding: 30rpx;
}

.section-block {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
  /* Make header clickable */
  cursor: pointer;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

/* Arrow icon */
.arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg); /* Down (expanded) */
  margin-right: 16rpx;
  transition: transform 0.2s ease;
  margin-bottom: 4rpx;
}

.arrow.collapsed {
  transform: rotate(-45deg); /* Right (collapsed) */
  margin-bottom: 0;
  margin-left: 4rpx; /* Slight adjustment */
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.select-all-btn {
  display: flex;
  align-items: center;
  padding: 10rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #666;
  margin-left: 10rpx;
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tags-wrapper.directions {
  /* Inherit generic tags-wrapper styles */
}

.tag {
  padding: 12rpx 30rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border-radius: 34rpx;
  text-align: center;
  transition: all 0.2s ease;
  min-width: 100rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Direction Tags - when selected */
.tag.selected {
  background-color: #007aff; /* Solid blue */
  color: #fff; /* White text */
  font-weight: 500;
}

.footer-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: sticky; 
  bottom: 0;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.selected-tags-area {
  width: 100%;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.selected-tags-scroll {
  display: flex;
  width: 100%;
  height: 60rpx; /* Adjusted height */
  flex-direction: row;
}

.selected-tags-scroll ::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.selected-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  background-color: #007aff;
  color: #fff;
  font-size: 24rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
  height: 56rpx;
  transition: all 0.2s;
}

.chip-close-icon {
  margin-left: 8rpx;
  /* icon size is handled by the component attribute, but we ensure layout flow */
}

.match-info {
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  padding: 0;
  margin: 0;
}

.confirm-btn:active {
  opacity: 0.9;
}
