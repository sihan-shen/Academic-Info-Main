/** pages/tutor-library/tutor-library.wxss */
.container {
  display: flex;
  flex-direction: column;
  background-color: #f7f8fa; /* Light gray background */
  min-height: 100vh;
  padding: 0; /* Reset app.wxss padding */
  align-items: stretch; /* Reset app.wxss align-items: center */
  box-sizing: border-box;
}

/* Header & Search */
.search-container {
  background-color: #ffffff;
  padding: 20rpx 24rpx; /* Reduced side padding slightly to make search bar wider */
  box-sizing: border-box;
  width: 100%;
}

.search-input-box {
  background: #f3f4f6; /* Gray input background */
  border-radius: 40rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  width: 100%; /* Ensure full width */
  box-sizing: border-box;
}

.search-icon {
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.placeholder {
  color: #999;
}

/* Content Body */
.content-body {
  padding: 30rpx;
  flex: 1;
}

/* Filter Card */
.filter-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-header .title {
  font-size: 30rpx;
  font-weight: 600; /* Bolder */
  color: #1e2939;
}

.card-header .more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #155dfc;
}

.arrow-right {
  width: 20rpx;
  height: 20rpx;
  margin-left: 6rpx;
  opacity: 0.8;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-tag {
  background: #f3f4f6;
  color: #4b5563;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 400;
}

/* Section Title */
.section-title {
  font-size: 28rpx;
  color: #4b5563;
  margin-bottom: 24rpx;
  font-weight: 400; /* Regular weight */
}

/* School List */
.school-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.school-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx; /* Ensure some height */
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start; /* Align top */
  margin-bottom: 16rpx;
}

.school-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e2939;
}

.location {
  font-size: 24rpx;
  color: #9ca3af; /* Lighter gray */
}

.card-bottom {
  display: flex;
}

.tutor-count {
  font-size: 26rpx;
  color: #155dfc; /* Blue color for count */
  font-weight: 500;
}

/* Department Grid */
.department-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding-bottom: 60rpx; /* Space at bottom */
}

.department-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

/* City Filter Popup */
.city-filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s;
}

.city-filter-mask.show {
  opacity: 1;
  visibility: visible;
}

.city-filter-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s;
  display: flex;
  flex-direction: column;
}

.city-filter-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-close {
  padding: 10rpx;
}

.popup-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  min-height: 400rpx;
}

.city-group {
  margin-bottom: 40rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.group-cities {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.city-tag-large {
  background: #f3f4f6;
  color: #4b5563;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}