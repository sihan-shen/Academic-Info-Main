/* pages/coop-opportunities/coop-opportunities.wxss */
page {
  background-color: #f0f4fa;
}

.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面头部 */
.page-header {
  margin-bottom: 32rpx;
  padding: 20rpx 0;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666666;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  margin-bottom: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #3468b5;
  color: #ffffff;
  font-weight: 500;
}

/* 项目列表 */
.project-list {
  display: flex;
  flex-direction: column;
}

.coop-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.coop-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.coop-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.coop-tags {
  display: flex;
  flex-wrap: wrap;
}

.coop-tag {
  font-size: 22rpx;
  color: #3468b5;
  background: #e8f0fe;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.coop-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.coop-achievement {
  font-size: 24rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.achieve-label {
  font-weight: bold;
}

.coop-team-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 14rpx;
}

.coop-members {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 12rpx;
}

.member-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #d8e2f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #3468b5;
  font-weight: bold;
  margin-right: 10rpx;
}

.member-name {
  font-size: 24rpx;
  color: #555;
}

.coop-actions {
  display: flex;
  margin-top: 20rpx;
}

.btn-detail {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 2rpx solid #d0d8e4;
  color: #555;
  background: #fff;
}

.btn-detail.primary {
  background: #3468b5;
  color: #ffffff;
  border: none;
}

.btn-detail:active {
  opacity: 0.9;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
