/** pages/user/user.wxss **/

/* Override global .container from app.wxss */
.container {
  min-height: 100vh;
  height: auto;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: 0;
  background-color: #f5f6f8;
  box-sizing: border-box;
}

/* ===== Header Blue Area ===== */
.header-bg {
  background: linear-gradient(180deg, #4080c8 0%, #3468b5 100%);
  padding: 30rpx 36rpx 160rpx 36rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

/* Edit button - top right */
.edit-btn {
  position: absolute;
  top: 36rpx;
  right: 36rpx;
  z-index: 5;
  background: rgba(255,255,255,0.22);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #fff;
}

.edit-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid #fff;
  border-right: 3rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* User info row */
.user-info {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  margin-bottom: 28rpx;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 24rpx;
  background-color: #e8e8e8;
  margin-right: 28rpx;
  flex-shrink: 0;
  border: 3rpx solid rgba(255,255,255,0.5);
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 4rpx;
}

.name {
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  line-height: 1.2;
}

.vip-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(0,0,0,0.18);
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 12rpx;
  align-self: flex-start;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  background: #bbb;
  border-radius: 50%;
  margin-right: 10rpx;
}

.phone {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.role-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  align-self: flex-start;
}

/* Bio box */
.bio-box {
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 22rpx 28rpx;
  display: flex;
  align-items: center;
}

.bio-emoji {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.bio-text {
  font-size: 26rpx;
  opacity: 0.9;
}

/* ===== VIP Card ===== */
.vip-card {
  margin: -120rpx 30rpx 0 30rpx;
  background: linear-gradient(160deg, #f5deb3 0%, #eec97a 50%, #e8b94a 100%);
  border-radius: 28rpx;
  padding: 36rpx 30rpx 0 30rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 8rpx 30rpx rgba(180,130,40,0.18);
}

.vip-top {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.star-icon {
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  color: #e8b94a;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.vip-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}

.vip-features {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.vip-feat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feat-circle {
  width: 76rpx;
  height: 76rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  position: relative;
}

.feat-circle image {
  width: 38rpx;
  height: 38rpx;
}

/* 专属导师查询图标 - 人物+搜索 */
.icon-tutor {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

/* 人物头部 */
.icon-tutor::before {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: white;
  border-radius: 50%;
  top: 4rpx;
  left: 12rpx;
}

/* 人物身体 */
.icon-tutor::after {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 18rpx;
  background: white;
  border-radius: 50% 50% 0 0;
  bottom: 2rpx;
  left: 9rpx;
}

/* 加速智能匹配图标 - 闪电 */
.icon-match {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-match::before {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 22rpx solid white;
  top: 2rpx;
  left: 10rpx;
}

.icon-match::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 22rpx solid white;
  bottom: 2rpx;
  right: 10rpx;
}

/* 更多收藏位置图标 - 星星 */
.icon-collect {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-collect::before {
  content: '★';
  font-size: 32rpx;
  color: white;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  line-height: 1;
}

.vip-feat text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.vip-btn {
  background: #fff;
  border-radius: 0 0 28rpx 28rpx;
  margin: 0 -30rpx;
  padding: 26rpx 0;
  text-align: center;
}

.vip-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #d48806;
  letter-spacing: 2rpx;
}

/* ===== Menu Row ===== */
.menu-row {
  display: flex;
  justify-content: space-between;
  padding: 44rpx 40rpx 20rpx 40rpx;
}

.menu-item {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  opacity: 0.55;
}

.menu-text {
  font-size: 26rpx;
  color: #444;
}

.menu-arrow {
  font-size: 22rpx;
  color: #aaa;
  margin-left: 6rpx;
}

/* ===== Spacer ===== */
.spacer {
  flex: 1;
}

/* ===== Logout ===== */
.logout-wrap {
  padding: 0 50rpx 50rpx 50rpx;
}

.logout-btn {
  background: #fff;
  border-radius: 50rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid #f0f0f0;
}

.logout-btn image {
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
}

.logout-btn text {
  color: #e84d4f;
  font-size: 30rpx;
  font-weight: 500;
}
