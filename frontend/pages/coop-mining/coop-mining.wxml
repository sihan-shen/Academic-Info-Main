<view class="container">
  <!-- 合作数据概览 -->
  <view class="section-title">合作数据概览</view>
  
  <view class="overview-cards">
    <!-- 活跃合作领域 -->
    <view class="overview-card">
      <view class="card-icon">
        <text class="icon">🔗</text>
      </view>
      <view class="card-content">
        <text class="card-label">活跃合作领域</text>
        <text class="card-subtitle">TOP3</text>
        <view class="tags">
          <text class="tag" wx:for="{{activeCooperationFields}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 潜在合作项目 -->
    <view class="overview-card" bindtap="navigateToCoopList">
      <view class="card-icon yellow">
        <text class="icon">💡</text>
      </view>
      <view class="card-content">
        <text class="card-label">潜在合作项目</text>
        <text class="card-number">{{potentialProjectCount}}个</text>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 推荐合作项目 -->
  <view class="section-title">为您推荐的合作项目</view>

  <view class="project-list">
    <view class="project-card" wx:for="{{recommendedProjects}}" wx:key="id" bindtap="navigateToProjectDetail" data-id="{{item.id}}">
      <view class="project-header">
        <text class="project-title">{{item.title}}</text>
        <view class="project-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
      
      <text class="project-desc">{{item.description}}</text>
      
      <view class="project-achievement" wx:if="{{item.achievement}}">
        <text class="achievement-label">过往成果：</text>
        <text class="achievement-text">{{item.achievement}}</text>
      </view>

      <view class="project-members">
        <text class="members-label">核心团队成员</text>
        <view class="members-list">
          <view class="member-item" wx:for="{{item.members}}" wx:for-item="member" wx:key="name">
            <view class="member-avatar">{{member.initial}}</view>
            <text class="member-name">{{member.name}}</text>
            <text class="member-school" wx:if="{{member.school}}">({{member.school}})</text>
          </view>
        </view>
      </view>

      <view class="view-detail-btn">查看合作详情</view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
