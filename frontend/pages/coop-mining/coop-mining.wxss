/* pages/coop-mining/coop-mining.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f0fe 0%, #f5f7fa 100%);
  padding: 20rpx 24rpx 40rpx;
}

/* ========== 区块标题 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 24rpx 0 20rpx;
  padding-left: 8rpx;
}

/* ========== 概览卡片区域 ========== */
.overview-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.overview-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  position: relative;
}

.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.card-icon.yellow {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #1a1a1a;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.card-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #3468b5;
  margin-top: 8rpx;
}

.card-arrow {
  font-size: 40rpx;
  color: #ccc;
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
}

/* ========== 项目卡片 ========== */
.project-list {
  margin-top: 10rpx;
}

.project-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.project-header {
  margin-bottom: 20rpx;
}

.project-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.project-tags .tag {
  font-size: 22rpx;
  color: #3468b5;
  background: #e8f0fe;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.project-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.project-achievement {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.achievement-label {
  font-size: 24rpx;
  color: #2e7d32;
  font-weight: 600;
}

.achievement-text {
  font-size: 24rpx;
  color: #4caf50;
  line-height: 1.5;
}

.project-members {
  margin-bottom: 28rpx;
}

.members-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.members-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #3468b5;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.member-school {
  font-size: 24rpx;
  color: #999;
}

.view-detail-btn {
  background: linear-gradient(135deg, #3468b5 0%, #2c5aa0 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(52, 104, 181, 0.3);
}

.view-detail-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 加载状态 ========== */
.loading-state {
  text-align: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #bbb;
}
