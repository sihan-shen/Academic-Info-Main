/** pages/edit-profile/edit-profile.wxss **/

page {
  background-color: #f5f6f8;
}

.page {
  padding: 24rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Each row card */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background-color 0.3s;
}

.card:active {
  background-color: #f5f6f8;
}

/* Avatar card is taller */
.avatar-card {
  padding: 36rpx 30rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
  flex-shrink: 0;
}

.right {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.value {
  font-size: 30rpx;
  color: #333;
  margin-right: 12rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.value.muted {
  color: #999;
  font-size: 26rpx;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* Avatar */
.avatar-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
}

.camera-icon {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #3468b5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.camera-text {
  font-size: 18rpx;
  line-height: 1;
}

/* 模态框遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 999;
}

/* 模态框 */
.modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal.show {
  transform: translateY(0);
}

.modal-content {
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}

/* 模态框头部 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  cursor: pointer;
}

/* 模态框主体 */
.modal-body {
  padding: 40rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.modal-input:focus {
  border-color: #3468b5;
}

.modal-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.modal-textarea:focus {
  border-color: #3468b5;
}

/* 选择器列表 */
.picker-list {
  display: flex;
  flex-direction: column;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
  color: #333;
  transition: background-color 0.3s;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item:active {
  background-color: #f5f6f8;
}

.picker-item.active {
  color: #3468b5;
  font-weight: 500;
}

.check-icon {
  font-size: 32rpx;
  color: #3468b5;
  font-weight: bold;
}

/* 模态框底部 */
.modal-footer {
  display: flex;
  padding: 24rpx 40rpx 40rpx;
  gap: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel,
.btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 1;
}

.btn-cancel {
  background-color: #f5f6f8;
  color: #666;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  background-color: #3468b5;
  color: #ffffff;
  border: none;
  line-height: 1;
}

.btn-confirm::after {
  border: none;
}

.btn-cancel:active {
  background-color: #e8e9eb;
}

.btn-confirm:active {
  opacity: 0.85;
}
