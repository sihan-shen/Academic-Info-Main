/** pages/tutor-detail/tutor-detail.wxss */
.container {
  background-color: #f5f7fa;
  min-height: 100vh; /* Changed from height to min-height to allow full scrolling */
  display: flex;
  flex-direction: column;
  padding: 0;
  box-sizing: border-box;
}

/* Header */
.tutor-header {
  background: white;
  padding: 30rpx 24rpx;
  margin-bottom: 0; /* Removed margin to connect with gradients if needed, or keep separate */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  width: 100%;
  box-sizing: border-box;
  z-index: 10;
  position: relative;
}

.header-top {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background-color: #eee;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 8rpx;
}

.school {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: #eef4ff;
  color: #2b7fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.header-stats {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* Tabs */
.tabs-sticky-wrapper {
  background: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  height: 90rpx; /* Fixed height to prevent layout shift */
  z-index: 15;
}

.tabs-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  animation: slideDown 0.2s ease-out;
}

@keyframes slideDown {
  from { transform: translateY(-100%); }
  to { transform: translateY(0); }
}

.tabs-placeholder {
  width: 100%;
  background: transparent;
}

.main-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.bottom-spacer {
  height: 300rpx; /* Increased spacer to ensure bottom content is visible */
  width: 100%;
  background: transparent; 
}

.content-body {
  padding-bottom: 0;
  background: #f5f7fa;
}

.tabs-scroll {
  background: white;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
  width: 100%;
}

.tabs-container {
  display: flex;
  padding: 0 10rpx;
  height: 90rpx; /* Ensure sufficient height for tabs */
  align-items: center;
}

.tab-item {
  display: inline-block;
  padding: 0 30rpx; /* Horizontal padding for spacing */
  height: 90rpx;
  line-height: 90rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
  flex-shrink: 0; /* Prevent shrinking */
}

.tab-item.active {
  color: #2b7fff;
  font-weight: 600;
  font-size: 30rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #2b7fff;
  border-radius: 3rpx;
}

/* Content */
.content-body {
  flex: 1;
  box-sizing: border-box;
}

.content-section {
  padding: 40rpx 24rpx; /* Balanced padding */
  /* background will be set via helper classes */
}

/* Alternating Background Gradients - Removed for solid color boxes */
.section-odd {
  background: transparent;
}

.section-even {
  background: transparent;
}

.section-container {
  /* background: white;  Removed default white to allow alternating */
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

/* Alternating Box Colors */
.section-odd .section-container {
  background-color: #ffffff;
}

.section-even .section-container {
  background-color: #e6f4ff;
}

.section-container:last-child {
  margin-bottom: 0;
}

.section-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: #2b7fff;
  border-radius: 4rpx;
}

.section-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* Timeline */
.timeline {
  padding: 10rpx 0;
}

.timeline-item {
  display: flex;
  margin-bottom: 0; /* Line handles spacing */
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-left {
  width: 160rpx;
  text-align: right;
  padding-right: 20rpx;
}

.timeline-year {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.timeline-center {
  width: 30rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: #2b7fff;
  border-radius: 50%;
  z-index: 2;
  margin-top: 6rpx; /* Align with text top */
}

.timeline-line {
  position: absolute;
  top: 26rpx;
  bottom: -20rpx; /* Connect to next dot */
  width: 2rpx;
  background: #e0e0e0;
  z-index: 1;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-right {
  flex: 1;
  padding-left: 20rpx;
  padding-bottom: 10rpx;
}

.timeline-content {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.timeline-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-work {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-honor {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-edu {
  background: #f6ffed;
  color: #52c41a;
}

/* Papers List */
.paper-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.paper-item {
  background: #f8f9fc;
  border-radius: 12rpx;
  padding: 24rpx;
}

.paper-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.paper-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #888;
}

.paper-journal {
  background: #eef4ff;
  color: #2b7fff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

/* Projects List */
.project-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.project-item {
  background: #f8f9fc;
  border-radius: 12rpx;
  padding: 24rpx;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.project-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.project-role {
  font-size: 24rpx;
  color: #2b7fff;
  background: rgba(43, 127, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.project-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
  box-sizing: border-box;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  font-size: 20rpx;
  color: #6a7282;
  min-width: 80rpx;
}

.action-btn image {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.action-btn image.collected {
  /* Add specific style if using a different icon or filter */
}

.contact-btn {
  flex: 1;
  background: linear-gradient(135deg, #2b7fff, #155dfc);
  color: white;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(43, 127, 255, 0.3);
}

/* Graph Styles */
.graph-box {
  width: 100%;
  background: #1a2a4a;
  border-radius: 12rpx;
  padding: 30rpx;
  box-sizing: border-box;
  color: white;
}

.graph-content {
  position: relative;
  height: 360rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.graph-caption {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 20rpx;
}

.graph-node {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.node-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.node-label {
  font-size: 22rpx;
  color: white;
}

.circle-you {
  background-color: #4b89ff;
  width: 70rpx;
  height: 70rpx;
  box-shadow: 0 0 15rpx rgba(75, 137, 255, 0.4);
}

.circle-blue {
  background-color: #5c8ae6;
}

.circle-orange {
  background-color: #fca43d;
}

.circle-green {
  background-color: #43b359;
}

.circle-red {
  background-color: #f26868;
}

.circle-purple {
  background-color: #9b59b6;
}

/* Loading and Empty States */
.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 20rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

/* Dynamic graph line */
.graph-line-dynamic {
  position: absolute;
  left: 50%;
  top: 50%;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.2);
  transform-origin: 0 50%;
}

.graph-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}

.graph-loading-text,
.graph-empty-text {
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
}

/* Positioning */
.node-center {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.node-tl {
  top: 10%;
  left: 10%;
}

.node-tr {
  top: 10%;
  right: 10%;
}

.node-bl {
  bottom: 10%;
  left: 10%;
}

.node-br {
  bottom: 10%;
  right: 10%;
}

/* Connecting Lines */
.graph-line {
  position: absolute;
  background-color: rgba(255, 255, 255, 0.2);
  height: 2rpx;
  transform-origin: 0 50%;
  z-index: 1;
}

/* Simplified lines using manual rotation/positioning for this specific layout */
/* These values are approximations to connect center to corners */
.line-tl {
  top: 50%;
  left: 50%;
  width: 40%;
  transform: rotate(215deg);
}

.line-tr {
  top: 50%;
  left: 50%;
  width: 40%;
  transform: rotate(325deg);
}

.line-bl {
  top: 50%;
  left: 50%;
  width: 40%;
  transform: rotate(145deg);
}

.line-br {
  top: 50%;
  left: 50%;
  width: 40%;
  transform: rotate(35deg);
}

/* Decorative Search Icon */
.graph-icon-search {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  opacity: 0.8;
}

.search-glass {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

.search-glass::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 10rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  transform: rotate(45deg);
}

/* ===== 学术合作关系图谱 - 现代专业版 ===== */

.scholar-network-container {
  position: relative;
  width: 100%;
  height: 380rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
}

/* 背景纹理 - 简洁白底风格，无需纹理 */
.network-bg-pattern {
  display: none;
}

/* 连接线层 - CSS实现 */
.connections-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.curve-line {
  position: absolute;
  height: 1rpx;
  background: #d9d9d9;
  transform-origin: 0 50%;
  z-index: 1;
}

/* 节点层 */
.network-nodes {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
}

/* 中心导师节点 */
.center-scholar-wrapper {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -75rpx;
  margin-top: -60rpx;
  z-index: 15;
}

.center-scholar-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 16rpx;
  min-width: 140rpx;
  max-width: 160rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  opacity: 0;
  transform: scale(0.6);
  animation: popIn 0.5s ease-out forwards;
  border: 3rpx solid #2b7fff;
}

@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 光晕效果 - 简洁白底风格，无需光晕 */
.node-glow {
  display: none;
}

.center-glow {
  display: none;
}

.scholar-avatar-wrapper {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.center-wrapper {
  width: 84rpx;
  height: 84rpx;
}

.scholar-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: block;
}

.center-avatar {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(99, 102, 241, 0.2);
}

.status-indicator {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.status-indicator.online {
  background: #10b981;
  box-shadow: 0 0 8rpx rgba(16, 185, 129, 0.6);
}

.scholar-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10rpx;
  width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.scholar-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #1e293b;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  line-height: 1.3;
}

.center-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  max-width: 140rpx;
}

.scholar-role {
  font-size: 18rpx;
  color: #2b7fff;
  background: rgba(43, 127, 255, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-top: 6rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 合作者节点 */
.peer-scholar-wrapper {
  position: absolute;
  z-index: 15;
  margin-left: -55rpx;
  margin-top: -45rpx;
}

.peer-scholar-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 12rpx;
  min-width: 100rpx;
  max-width: 120rpx;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  opacity: 0;
  transform: scale(0.6);
  transition: all 0.3s ease;
  border: 2rpx solid #999999;
}

/* 入场动画延迟 - 简洁 */
.anim-delay-0 { animation: popIn 0.4s ease-out 0.05s forwards; }
.anim-delay-1 { animation: popIn 0.4s ease-out 0.15s forwards; }
.anim-delay-2 { animation: popIn 0.4s ease-out 0.25s forwards; }
.anim-delay-3 { animation: popIn 0.4s ease-out 0.35s forwards; }
.anim-delay-4 { animation: popIn 0.4s ease-out 0.45s forwards; }

/* Hover/点击效果 */
.peer-scholar-node:active {
  transform: scale(1.12);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.center-scholar-node:active {
  transform: scale(1.08);
}

/* 节点边框样式 - 深灰色边框 */
.peer-indigo {
  border: 2rpx solid #666666;
}

.peer-violet {
  border: 2rpx solid #666666;
}

.peer-blue {
  border: 2rpx solid #666666;
}

.peer-cyan {
  border: 2rpx solid #666666;
}

.peer-teal {
  border: 2rpx solid #666666;
}

.coop-count {
  font-size: 18rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 6rpx;
  white-space: nowrap;
}

/* 悬停提示 - 简洁风格 */
.network-tooltip {
  position: absolute;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid #f0f0f0;
  animation: tooltipEnter 0.2s ease-out;
}

@keyframes tooltipEnter {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tooltip-content {
  display: flex;
  flex-direction: column;
}

.tooltip-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.tooltip-detail {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
}

.network-loading,
.network-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 1rpx solid #f0f0f0;
}

.network-loading .loading-text,
.network-empty .empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ===== 合作者列表 - 简洁版 ===== */
.collaborators-list {
  margin-top: 24rpx;
}

.list-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2b7fff;
}

.collab-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.3s;
  border: 1rpx solid #f0f0f0;
}

.collab-item:active {
  background: #f8f9fa;
  transform: translateX(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.collab-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #e0e7ff;
}

.collab-info {
  flex: 1;
}

.collab-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.collab-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-right: 12rpx;
}

.collab-relation-tag {
  font-size: 20rpx;
  color: #2b7fff;
  background: rgba(43,127,255,0.1);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.collab-school {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.collab-project {
  font-size: 22rpx;
  color: #9ca3af;
}

.collab-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.section-subtitle {
  font-size: 22rpx;
  color: #666;
  margin-left: 12rpx;
  font-weight: 500;
}

/* ===== 点击展开功能样式 ===== */

/* 点击提示 */
.network-hint {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 5;
  background: rgba(255, 255, 255, 0.95);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.hint-text {
  font-size: 20rpx;
  color: #666;
}

/* 全屏展开遮罩 */
.network-expanded-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 展开容器 */
.expanded-container {
  width: 90vw;
  height: 85vh;
  background: #ffffff;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 关闭按钮 */
.close-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.close-btn:active {
  transform: scale(0.9);
  background: #f3f4f6;
}

.close-icon {
  font-size: 40rpx;
  color: #6b7280;
  font-weight: 300;
  line-height: 1;
}

/* 展开头部 */
.expanded-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  flex-shrink: 0;
}

.expanded-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.expanded-subtitle {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 放大的图谱 */
.expanded-graph {
  position: relative;
  width: 100%;
  height: 55vh;
  flex-shrink: 0;
  min-height: 420rpx;
}

.expanded-connections {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 5;
}

.expanded-line {
  position: absolute;
  height: 1rpx;
  background: #d9d9d9;
  transform-origin: 0 50%;
  z-index: 5;
}

.expanded-nodes {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
}

/* 展开视图中的节点 */
.expanded-center-wrapper {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -100rpx;
  margin-top: -100rpx;
  z-index: 20;
}

.expanded-center-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 20rpx;
  min-width: 180rpx;
  max-width: 220rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
  border: 3rpx solid #2b7fff;
}

.expanded-center-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.expanded-center-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-top: 14rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.expanded-center-role {
  font-size: 22rpx;
  color: #2b7fff;
  background: rgba(43, 127, 255, 0.1);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
  white-space: nowrap;
}

.expanded-peer-wrapper {
  position: absolute;
  z-index: 10;
}

.expanded-peer-wrapper {
  position: absolute;
  z-index: 20;
  margin-left: -70rpx;
  margin-top: -70rpx;
}

.expanded-peer-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  min-width: 130rpx;
  max-width: 150rpx;
  padding: 14rpx 18rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
  border: 2rpx solid #666666;
}

.expanded-peer-node:active {
  transform: scale(1.08);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
}

.expanded-peer-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.expanded-peer-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  margin-top: 10rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  line-height: 1.3;
}

.expanded-peer-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 6rpx;
  width: 100%;
}

.peer-stat {
  font-size: 18rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
  white-space: nowrap;
}

/* 展开的合作详情列表 */
.expanded-collab-list {
  flex: 1;
  padding: 0 40rpx 40rpx;
  margin-top: 20rpx;
}

.expanded-list-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #2b7fff;
}

.expanded-collab-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.expanded-collab-item:active {
  background: #f5f3ff;
  transform: translateX(8rpx);
}

.collab-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.collab-dot.peer-indigo { background: #999; }
.collab-dot.peer-violet { background: #999; }
.collab-dot.peer-blue { background: #999; }
.collab-dot.peer-cyan { background: #999; }
.collab-dot.peer-teal { background: #999; }

.expanded-collab-info {
  flex: 1;
}

.expanded-collab-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.expanded-collab-school {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 4rpx;
}

.expanded-collab-detail {
  font-size: 22rpx;
  color: #2b7fff;
  display: block;
}

.expanded-collab-stats {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.stat-badge {
  font-size: 22rpx;
  color: #666;
  background: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}
