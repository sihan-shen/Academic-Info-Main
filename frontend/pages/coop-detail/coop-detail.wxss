/* pages/coop-detail/coop-detail.wxss */
page {
  background-color: #f0f4fa;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部标题区域 */
.header {
  background: linear-gradient(180deg, #4a76c8 0%, #3468b5 100%);
  padding: 40rpx 32rpx 32rpx;
  color: #ffffff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.project-title {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1.4;
  flex: 1;
  margin-right: 20rpx;
  margin-bottom: 0;
}

.favorite-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star {
  font-size: 48rpx;
  color: #FFC107; /* Brighter Amber/Gold */
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
}

/* 基本信息卡片 */
.info-card {
  background: #ffffff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #666666;
  min-width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333333;
  flex: 1;
}

.info-value.highlight {
  color: #3468b5;
  font-weight: bold;
}

/* 成果展示横幅 */
.achievement-banner {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  margin: 0 24rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
}

.achievement-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.achievement-text {
  font-size: 26rpx;
  color: #1565c0;
  line-height: 1.6;
  flex: 1;
}

/* 章节 */
.section {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3468b5;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8f0fe;
}

/* 子章节 */
.subsection {
  margin-bottom: 32rpx;
}

.subsection:last-child {
  margin-bottom: 0;
}

.subsection-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subsection-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
}

/* 价值列表 */
.value-list,
.area-list {
  padding-left: 20rpx;
}

.value-item,
.area-item {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 12rpx;
  position: relative;
  padding-left: 24rpx;
}

.value-item:before,
.area-item:before {
  content: '•';
  position: absolute;
  left: 0;
  color: #3468b5;
  font-weight: bold;
}

/* 导师列表 */
.mentor-list {
  display: flex;
  flex-direction: column;
}

.mentor-card {
  background: #f8fafc;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.mentor-card:last-child {
  margin-bottom: 0;
}

.mentor-header {
  display: flex;
  align-items: center;
}

.mentor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #d8e2f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #3468b5;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.mentor-info {
  flex: 1;
}

.mentor-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.mentor-title {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.mentor-tags {
  display: flex;
  flex-wrap: wrap;
}

.mentor-tag {
  font-size: 20rpx;
  color: #3468b5;
  background: #e8f0fe;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}

.mentor-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.contact-btn {
  background: #3468b5;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 1.4;
}

.contact-btn::after {
  border: none;
}

/* 合作方详情 */
.partner-detail {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.partner-detail-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.partner-link {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #e8f0fe;
  border-radius: 12rpx;
}

.link-text {
  font-size: 26rpx;
  color: #3468b5;
  text-decoration: underline;
}

/* AI分析 */
.ai-analysis {
  display: flex;
  flex-direction: column;
}

.analysis-item {
  background: #f8fafc;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 80rpx;
}

.analysis-item:last-child {
  margin-bottom: 0;
}

.analysis-number {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  width: 48rpx;
  height: 48rpx;
  background: #3468b5;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.analysis-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.analysis-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
}

.analysis-footer {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fff9e6;
  border-radius: 12rpx;
  border-left: 4rpx solid #ffa726;
}

.footer-text {
  font-size: 24rpx;
  color: #f57c00;
  line-height: 1.6;
}

/* 底部操作按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 24rpx;
  display: flex;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  border: none;
  line-height: 1.4;
}

.btn-secondary {
  background: #ffffff;
  color: #3468b5;
  border: 2rpx solid #3468b5;
  margin-right: 20rpx;
}

.btn-secondary.favorited {
  background: #e8f0fe;
  color: #3468b5;
  border: 2rpx solid #3468b5;
}

.btn-primary {
  background: #3468b5;
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}

.btn-secondary:active {
  background: #e8f0fe;
}

.btn-primary:active {
  opacity: 0.85;
}
