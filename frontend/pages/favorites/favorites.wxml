<view class="container">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'tutor' ? 'active' : ''}}" bindtap="switchTab" data-tab="tutor">
      <text class="tab-text">收藏导师</text>
    </view>
    <view class="tab-item {{activeTab === 'project' ? 'active' : ''}}" bindtap="switchTab" data-tab="project">
      <text class="tab-text">收藏项目</text>
    </view>
  </view>

  <!-- 导师收藏列表 -->
  <view class="content" wx:if="{{activeTab === 'tutor'}}">
    <view class="empty-state" wx:if="{{tutorList.length === 0 && !isLoading}}">
      <image class="empty-icon" src="/images/empty-favorites.png" mode="aspectFit"></image>
      <text class="empty-text">暂无收藏的导师</text>
      <text class="empty-subtitle">去发现和收藏感兴趣的导师吧</text>
    </view>

    <view class="tutor-list">
      <view class="tutor-card" wx:for="{{tutorList}}" wx:key="id">
        <view class="card-content" bindtap="viewTutorDetail" data-id="{{item.id}}">
          <image class="tutor-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="tutor-info">
            <view class="tutor-header">
              <text class="tutor-name">{{item.name}}</text>
            </view>
            <view class="tutor-school">{{item.school}} · {{item.department}}</view>
            <view class="tutor-tags" wx:if="{{item.direction}}">
              <text class="tag">{{item.direction}}</text>
            </view>
            <view class="tutor-date">
              <text class="date-text">收藏于 {{item.date}}</text>
            </view>
          </view>
        </view>
        <view class="card-actions">
          <view class="btn-remove" bindtap="onRemoveTutor" data-id="{{item.id}}">
            <text class="remove-text">取消收藏</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 项目收藏列表 -->
  <view class="content" wx:if="{{activeTab === 'project'}}">
    <view class="empty-state" wx:if="{{projectList.length === 0 && !isLoading}}">
      <image class="empty-icon" src="/images/empty-favorites.png" mode="aspectFit"></image>
      <text class="empty-text">暂无收藏的项目</text>
      <text class="empty-subtitle">去发现和收藏感兴趣的合作项目吧</text>
    </view>

    <view class="project-list">
      <view class="project-card" wx:for="{{projectList}}" wx:key="id">
        <view class="card-content" bindtap="viewProjectDetail" data-id="{{item.id}}">
          <view class="project-header">
            <text class="project-title">{{item.title}}</text>
            <view class="project-tags" wx:if="{{item.tags.length > 0}}">
              <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
          <view class="project-date">
            <text class="date-text">收藏于 {{item.date}}</text>
          </view>
        </view>
        <view class="card-actions">
          <view class="btn-remove" bindtap="onRemoveProject" data-id="{{item.id}}">
            <text class="remove-text">取消收藏</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
