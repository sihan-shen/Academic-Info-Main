/** pages/vip/vip.wxss **/

page {
  background: #f5f6f8;
  min-height: 100vh;
}

.page {
  padding: 24rpx 28rpx 60rpx;
  box-sizing: border-box;
}

/* ===== Section 1: Status Card ===== */
.status-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e8e8e8;
}

.status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.status-left {
  display: flex;
  align-items: center;
}

.status-icon {
  width: 56rpx;
  height: 56rpx;
  background: #f2f3f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.status-label {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.3;
}

.status-sub {
  font-size: 20rpx;
  color: #aaa;
}

.status-badge {
  border: 2rpx solid #ccc;
  border-radius: 24rpx;
  padding: 6rpx 20rpx;
}

.status-badge text {
  font-size: 22rpx;
  color: #999;
}

.status-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.7;
}

/* ===== Section 2: Member Card ===== */
.member-card {
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(52, 104, 181, 0.1);
}

.member-header {
  background: linear-gradient(135deg, #5b8def 0%, #3d6fbf 100%);
  padding: 36rpx 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.member-body {
  background: #fff;
  padding: 30rpx 32rpx 36rpx;
}

.member-left {
  display: flex;
  align-items: center;
}

.member-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  margin-right: 18rpx;
  flex-shrink: 0;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.member-label {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
}

.member-sub {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.member-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price-tag {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.price-num {
  font-size: 52rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* Feature List */
.feature-list {
  margin-bottom: 32rpx;
}

.feature-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.feature-row text {
  font-size: 26rpx;
  color: #555;
}

.feat-ico {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.feat-ico-search {
  background: #f0f1f3;
  font-size: 22rpx;
}

.feat-ico-check {
  background: #e6f7ed;
  color: #2da55e;
  font-size: 20rpx;
  font-weight: bold;
}

/* Buy Button */
.buy-btn {
  background: linear-gradient(90deg, #4a88d0, #3468b5);
  border-radius: 44rpx;
  padding: 26rpx 0;
  text-align: center;
}

.buy-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

/* ===== Section 3: Trial Card ===== */
.trial-card {
  background: linear-gradient(180deg, #4a7fd6 0%, #3d60c0 50%, #5b3fa0 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx 0;
  margin-bottom: 24rpx;
  color: #fff;
  overflow: hidden;
  position: relative;
}

.trial-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #ff8c42, #e84393, #7c3aed);
}

.trial-tag-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.trial-tag {
  background: rgba(255,255,255,0.15);
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
  display: inline-flex;
}

.trial-tag text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
}

.trial-title-row {
  text-align: center;
  margin-bottom: 10rpx;
}

.trial-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.trial-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 36rpx;
}

/* Trial Icons Panel */
.trial-icons-panel {
  background: rgba(255,255,255,0.12);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  margin-bottom: 28rpx;
}

.trial-icons {
  display: flex;
  align-items: center;
  justify-content: center;
}

.trial-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trial-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.trial-ico-orange {
  background: #f5a623;
}

.trial-ico-purple {
  background: #6c5ce7;
}

.trial-icon-emoji {
  font-size: 40rpx;
}

.trial-icon-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.trial-arrow-text {
  font-size: 36rpx;
  color: rgba(255,255,255,0.5);
  margin: 0 40rpx;
}

/* Trial Features */
.trial-features {
  margin-bottom: 36rpx;
}

.trial-feat-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.trial-feat-row text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.check-green {
  color: #66d9a0;
  font-size: 26rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

.highlight {
  color: #ffd700;
  font-weight: bold;
}

/* Trial Button */
.trial-btn {
  background: linear-gradient(90deg, #ff8c42, #e84393);
  border-radius: 44rpx;
  padding: 26rpx 0;
  text-align: center;
  margin-bottom: 36rpx;
}

.trial-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

/* ===== Section 4: Service Card ===== */
.service-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.service-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.service-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.service-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  font-size: 22rpx;
  color: #999;
  line-height: 1.8;
}
