/** pages/help/help.wxss **/

page {
  background-color: #eef3fc;
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
  padding-bottom: 220rpx;
}

/* ===== Search Bar ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #dce5f5;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
  font-size: 26rpx;
}

/* ===== Tags ===== */
.tag-scroll {
  white-space: nowrap;
  margin-bottom: 32rpx;
}

.tag-list {
  display: flex;
  gap: 18rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #fff;
  color: #5a5a5a;
  border: 2rpx solid #d8e2f0;
  flex-shrink: 0;
}

.tag-ico {
  margin-right: 8rpx;
  font-size: 22rpx;
}

.tag-active {
  background: #3b7dd8;
  color: #fff;
  border-color: #3b7dd8;
}

/* ===== Section ===== */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.section-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* ===== Hot Questions Grid ===== */
.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.hot-item text {
  font-size: 24rpx;
  color: #444;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== Question List ===== */
.question-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 30rpx;
}

.q-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.q-tag {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.q-tag-blue {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-tag-green {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-tag-purple {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-tag-orange {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-tag-red {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-tag-teal {
  background: #e8f0fe;
  color: #3a7bd5;
}

.q-chevron {
  font-size: 28rpx;
  color: #bbb;
  transition: transform 0.2s;
}

.q-chevron-up {
  transform: rotate(180deg);
}

.q-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.q-answer {
  margin-top: 16rpx;
}

.q-answer-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ===== Bottom Spacer ===== */
.bottom-spacer {
  height: 60rpx;
}

/* ===== Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4a8cf0 0%, #3b7dd8 100%);
  padding: 30rpx 32rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 100;
}

.bottom-info {
  display: flex;
  align-items: center;
}

.bottom-bubble {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.bottom-text-wrap {
  display: flex;
  flex-direction: column;
}

.bottom-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
}

.bottom-sub {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.bottom-btns {
  display: flex;
  gap: 16rpx;
}

.btn-chat {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #3b7dd8;
  background: #fff;
  border: 2rpx solid #fff;
}

.btn-phone {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.4);
}

.btn-ico {
  font-size: 22rpx;
  margin-right: 6rpx;
}
