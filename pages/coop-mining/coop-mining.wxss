.page {
  min-height: 100vh;
  background: #f0f4fa;
  padding: 0 24rpx 60rpx;
}

/* ========== 区块标题 ========== */
.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #3468b5;
  margin: 32rpx 0 20rpx;
}

/* ========== 数据概览 ========== */
.stat-row {
  display: flex;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
}

.stat-top-row {
  display: flex;
  align-items: center;
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.stat-icon.green {
  background: #e8f5e9;
}

.stat-icon.blue {
  background: #e8f0fe;
}

.stat-text {
  flex: 1;
}

.stat-sub {
  font-size: 22rpx;
  color: #888;
  white-space: pre-line;
  line-height: 1.4;
}

.stat-value-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-top: 12rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #3468b5;
  margin-top: 8rpx;
}

.stat-unit {
  font-size: 26rpx;
  font-weight: normal;
  color: #666;
  margin-left: 4rpx;
}

.stat-arrow {
  font-size: 36rpx;
  color: #bbb;
  margin-left: 8rpx;
}

/* ========== 合作卡片 ========== */
.coop-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.coop-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.coop-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.coop-tags {
  display: flex;
  gap: 10rpx;
}

.coop-tag {
  font-size: 22rpx;
  color: #3468b5;
  background: #e8f0fe;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.coop-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.coop-achievement {
  font-size: 24rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.achieve-label {
  font-weight: bold;
}

.coop-team-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 14rpx;
}

.coop-members {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #d8e2f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #3468b5;
  font-weight: bold;
}

.member-name {
  font-size: 24rpx;
  color: #555;
}

.coop-actions {
  display: flex;
  gap: 20rpx;
}

.btn-detail {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  border: 2rpx solid #d0d8e4;
  font-size: 26rpx;
  color: #555;
  background: #fff;
}

.btn-apply {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #fff;
  background: #3468b5;
}

.btn-detail:active {
  background: #f5f5f5;
}

.btn-apply:active {
  opacity: 0.85;
}

/* ========== 关系图谱 ========== */
.graph-card {
  background: #1e2a4a;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.graph-zoom {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  font-size: 32rpx;
  z-index: 2;
  background: rgba(255,255,255,0.15);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.graph-area {
  position: relative;
  height: 400rpx;
}

.graph-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.node {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.node-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.node-dot.dot-blue {
  background: #5b8def;
}

.node-dot.dot-blue-lg {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #5b8def;
}

.node-dot.dot-orange {
  background: #f5a623;
}

.node-dot.dot-green {
  background: #4caf50;
}

.node-dot.dot-red {
  background: #e57373;
}

.node-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
}

.node-label-center {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.graph-hint {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 16rpx;
}

/* ========== 发布按钮 ========== */
.publish-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #3468b5;
  background: #fff;
  border: 2rpx solid #3468b5;
  margin: 0 24rpx 40rpx;
}

.publish-btn:active {
  background: #e8f0fe;
}
