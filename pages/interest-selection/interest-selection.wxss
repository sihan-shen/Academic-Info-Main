.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #fff;
  padding: 0;
  box-sizing: border-box;
}

.filter-wrapper {
  flex: 1;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* Important for inner scroll */
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tags-wrapper.subjects {
  margin-bottom: 40rpx;
  /* Subjects usually fit in one view or wrap slightly */
}

.directions-scroll {
  flex: 1;
  /* Ensure scroll view takes remaining space */
  overflow-y: auto;
}

.tags-wrapper.directions {
  padding-bottom: 40rpx;
}

.tag {
  padding: 12rpx 30rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border-radius: 34rpx;
  text-align: center;
  transition: all 0.2s ease;
  min-width: 100rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Specific styles for Subject vs Direction if needed */

/* Subject Tags - when selected */
.subject-tag.selected {
  background-color: #e6f7ff; /* Light blue background */
  color: #007aff; /* Blue text */
  font-weight: 500;
}

/* Direction Tags - when selected */
.direction-tag.selected {
  background-color: #007aff; /* Solid blue */
  color: #fff; /* White text */
  font-weight: 500;
}

.footer-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: sticky; 
  bottom: 0;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
}

.match-info {
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  padding: 0;
  margin: 0;
}

.confirm-btn:active {
  opacity: 0.9;
}
