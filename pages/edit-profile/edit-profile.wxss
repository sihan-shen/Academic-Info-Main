/** pages/edit-profile/edit-profile.wxss **/

page {
  background-color: #f5f6f8;
}

.page {
  padding: 24rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Each row card */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Avatar card is taller */
.avatar-card {
  padding: 36rpx 30rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
  flex-shrink: 0;
}

.right {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.value {
  font-size: 30rpx;
  color: #333;
  margin-right: 12rpx;
}

.value.muted {
  color: #999;
  font-size: 26rpx;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* Avatar */
.avatar-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
}

.camera-icon {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #3468b5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.camera-text {
  font-size: 18rpx;
  line-height: 1;
}
