<view class="page">
  <!-- 头像 -->
  <view class="card avatar-card">
    <text class="label">头像</text>
    <view class="avatar-wrap">
      <image class="avatar-img" src="/images/tutor-zhang.png"></image>
      <view class="camera-icon">
        <text class="camera-text">📷</text>
      </view>
    </view>
  </view>

  <!-- 姓名 -->
  <view class="card">
    <text class="label">姓名</text>
    <view class="right">
      <text class="value">{{userInfo.name}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 手机号 -->
  <view class="card">
    <text class="label">手机号</text>
    <view class="right">
      <text class="value">{{userInfo.phone}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 性别 -->
  <view class="card">
    <text class="label">性别</text>
    <view class="right">
      <text class="value">{{userInfo.gender}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 学术状态 -->
  <view class="card">
    <text class="label">学术状态</text>
    <view class="right">
      <text class="value">{{userInfo.academicStatus}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 个性签名 -->
  <view class="card">
    <text class="label">个性签名</text>
    <view class="right">
      <text class="value muted">{{userInfo.signature}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 所属机构 -->
  <view class="card">
    <text class="label">所属机构</text>
    <view class="right">
      <text class="value"></text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 当前导师 -->
  <view class="card">
    <text class="label">当前导师</text>
    <view class="right">
      <text class="value"></text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 学术成就 -->
  <view class="card">
    <text class="label">学术成就</text>
    <view class="right">
      <text class="value muted">{{userInfo.signature}}</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
