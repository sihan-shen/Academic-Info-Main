/* pages/user/user.wxss */
.container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  display: block;
}

.user-card {
  margin-bottom: 24rpx;
}

.user-info-bg {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.user-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #eee;
  flex-shrink: 0;
  border: 1rpx solid #f0f0f0;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.role-tag {
  display: inline-flex;
  align-items: center;
  background: #e6f7ff;
  color: #1890ff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.vip-tag {
  display: inline-flex;
  font-size: 22rpx;
  color: #999;
}

.edit-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  height: fit-content;
}

.edit-btn text {
  font-size: 24rpx;
  color: #666;
}

.edit-btn image {
  width: 24rpx;
  height: 24rpx;
  margin-left: 6rpx;
  opacity: 0.6;
}

.bio {
  background: #f9f9f9;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.bio-text {
  color: #888;
}

/* VIP Banner */
.vip-banner {
  margin-bottom: 24rpx;
  background: linear-gradient(90deg, #333 0%, #1a1a1a 100%);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  color: #ffd700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.vip-icon-box {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 215, 0, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.vip-icon {
  width: 40rpx;
  height: 40rpx;
}

.vip-text {
  flex: 1;
}

.vip-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  background: linear-gradient(90deg, #ffd700, #fff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.vip-subtitle {
  font-size: 22rpx;
  opacity: 0.8;
  color: #ddd;
}

.vip-btn {
  background: linear-gradient(90deg, #ffd700, #ffa500);
  color: #333;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-weight: 600;
}

/* Feature Grid */
.feature-grid {
  display: flex;
  justify-content: space-between;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.33%;
}

.feature-item:active {
  opacity: 0.7;
}

.feature-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: #f0f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.feature-icon-box image {
  width: 40rpx;
  height: 40rpx;
}

.feature-item text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* Menu List */
.menu-list {
  background: white;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.menu-left text {
  font-size: 28rpx;
  color: #333;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.3;
}

.logout-btn {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.logout-btn image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}