<view class="container">
  <!-- User Info Card -->
  <view class="user-card">
    <view class="user-info-bg">
      <view class="user-main">
        <image class="avatar" src="/images/tutor-zhang.png"></image>
        <view class="info-content">
          <view class="name-row">
            <text class="name">学术研究者</text>
            <view class="role-tag">
              <text>硕士研究生</text>
            </view>
          </view>
          <text class="phone">138****5678</text>
          <view class="vip-tag">
            <text>未开通会员</text>
          </view>
        </view>
        <view class="edit-btn">
            <text>编辑</text>
            <image src="/images/edit-icon.png"></image>
        </view>
      </view>
      
      <view class="bio">
        <text class="bio-text">这位学者很懒，什么都没留下~</text>
      </view>
    </view>
  </view>

  <!-- VIP Banner -->
  <view class="vip-banner">
    <view class="vip-icon-box">
      <image class="vip-icon" src="/images/vip-icon.png"></image>
    </view>
    <view class="vip-text">
      <view class="vip-title">升级会员，解锁全部功能</view>
      <view class="vip-subtitle">每天低至1元，立即开通</view>
    </view>
    <view class="vip-btn">立即开通</view>
  </view>

  <!-- Feature Grid -->
  <view class="feature-grid">
    <view class="feature-item">
      <view class="feature-icon-box">
        <image src="/images/search-icon.png"></image>
      </view>
      <text>专属导师查询</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon-box">
        <image src="/images/search-icon.png"></image>
      </view>
      <text>加速智能匹配</text>
    </view>
    <view class="feature-item" bindtap="navigateToFavorites">
      <view class="feature-icon-box">
        <image src="/images/fav-icon.png"></image>
      </view>
      <text>更多收藏位置</text>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-list">
    <view class="menu-item">
      <view class="menu-left">
        <image class="menu-icon" src="/images/help-icon.png"></image>
        <text>帮助中心</text>
      </view>
      <image class="arrow-icon" src="/images/service-icon.png"></image>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <image class="menu-icon" src="/images/service-icon.png"></image>
        <text>客服中心</text>
      </view>
      <image class="arrow-icon" src="/images/service-icon.png"></image>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <image class="menu-icon" src="/images/privacy-icon.png"></image>
        <text>隐私设置</text>
      </view>
      <image class="arrow-icon" src="/images/service-icon.png"></image>
    </view>
  </view>

  <!-- Logout Button -->
  <view class="logout-btn" bindtap="onLogout">
    <image src="/images/logout-icon.png"></image>
    <text>退出登录</text>
  </view>
</view>
